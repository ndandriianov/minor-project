# ─── Базовое ───
APP_PORT=5051

# ОБЯЗАТЕЛЬНО смени в проде! 32+ символов случайной строки.
# Генерация: openssl rand -hex 32
JWT_SECRET=change-me-min-32-chars-random-string

# Включи в проде, чтобы упасть, если JWT_SECRET остался дефолтным
# FLASK_ENV=production

# Список разрешённых доменов фронта через запятую. В проде НЕ ставь "*"
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGINS=https://myapp.ru,https://www.myapp.ru

# ─── База данных ───
# По умолчанию SQLite (для прода желательно Postgres):
# DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/internships

# ─── DonationAlerts ───
DONATIONALERTS_USERNAME=
DONATIONALERTS_TOKEN=
DONATIONALERTS_POLL_SEC=60

# В проде ОБЯЗАТЕЛЬНО 0. Иначе любой может активировать себе премиум через /api/payments/mock-confirm.
ALLOW_MOCK_PAYMENTS=0

# ─── ИИ-помощник по резюме (опц.) ───
# Mistral / OpenRouter / OpenAI — любой OpenAI-совместимый
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.mistral.ai/v1
# OPENAI_MODEL=mistral-small-latest

# ─── SMTP (опц.) ───
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=no-reply@yourdomain.ru

# ─── Прочее ───
# DISABLE_SCHEDULER=1
# RATELIMIT_STORAGE=redis://redis:6379/0   # для multi-worker — нужен Redis
